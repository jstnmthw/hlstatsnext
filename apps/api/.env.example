# API Configuration
# Copy this file to .env and update values for your environment.

# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
DATABASE_URL="mysql://hlstatsnext:CHANGE_ME@localhost:3306/hlstatsnext"

# Frontend URL for CORS
FRONTEND_URL='http://localhost:3000'

# Encryption Key — generate with @repo/crypto or: openssl rand -base64 32
ENCRYPTION_KEY='CHANGE_ME_BASE64_32_BYTES'

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="CHANGE_ME_BASE64_32_BYTES"
BETTER_AUTH_URL=http://localhost:3000

# Observability (opt-in). See docs/OBSERVABILITY.md.
# When true, the API registers @envelop/prometheus and binds API_METRICS_PORT.
METRICS_ENABLED=false
API_METRICS_PORT=9092
