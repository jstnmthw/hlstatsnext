# Claude Code: ignore everything by default, then opt the team-shared bits
# back in. settings.local.json stays personal; settings.json + skills + agents
# + hooks are committed so a fresh clone gets the full team toolkit.
.claude/*
!.claude/agents/
!.claude/hooks/
!.claude/skills/
!.claude/settings.json

