# HLStatsNext Environment Configuration
# Copy to .env and update values as needed.
COMPOSE_PROJECT_NAME=hlstatsnext-dev

# User Configuration
USER_ID=1000
GROUP_ID=1000

# Database Configuration
DB_HOST=db
DB_PORT=3306
DB_NAME=hlstatsnext
DB_USER=hlstatsnext
DB_PASS=CHANGE_ME_DB_PASS
DB_ROOT_PASSWORD=CHANGE_ME_DB_ROOT
DB_CHARSET=utf8mb4

# Database Connection Pool Configuration
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=300000
DB_HEALTH_CHECK_INTERVAL=60000
DB_MAX_RETRIES=3

# RabbitMQ Configuration
RABBITMQ_USER=hlstats
RABBITMQ_PASSWORD=CHANGE_ME_RABBITMQ
RABBITMQ_VHOST=hlstats

# Grafana Configuration (optional, used by docker-compose.observability.yml)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA

# Note: app-side observability env vars (METRICS_ENABLED, METRICS_PORT, API_METRICS_PORT)
# live in per-app templates — the apps load their own .env from their cwd, not the
# repo root. See apps/api/.env.example and apps/daemon/.env.example.
