# Daemon Configuration
# Copy this file to .env and update values for your environment.

NODE_ENV=development

# Database Configuration
DATABASE_URL="mysql://hlstatsnext:CHANGE_ME@localhost:3306/hlstatsnext"

# Base64-encoded 32-byte encryption key
# Generate with: openssl rand -base64 32
# IMPORTANT: Always use single quotes to preserve special characters
ENCRYPTION_KEY='CHANGE_ME_BASE64_32_BYTES'

# Logging Configuration
LOG_LEVEL=info # Supported levels: error, warn, info, debug

# Ingress Server Configuration
INGRESS_PORT=27500 # UDP port for receiving game server logs (default: 27500)

# RabbitMQ Configuration
RABBITMQ_URL=amqp://hlstats:CHANGE_ME@localhost:5672/hlstats
RABBITMQ_USER=hlstats
RABBITMQ_PASSWORD=CHANGE_ME
RABBITMQ_VHOST=hlstats

# RCON Configuration
# Core RCON Settings
RCON_ENABLED=true                        # Enable/disable RCON functionality
RCON_TIMEOUT=5000                        # Connection timeout (ms)
RCON_MAX_RETRIES=3                       # Max retries per connection attempt
RCON_STATUS_INTERVAL=30000               # Monitoring interval (ms)

# Active Server Discovery
RCON_ACTIVE_SERVER_MAX_AGE_MINUTES=60    # Server activity threshold

# Retry & Backoff Configuration
RCON_MAX_CONSECUTIVE_FAILURES=10         # Failures before dormant state
RCON_BACKOFF_MULTIPLIER=2                # Exponential backoff multiplier
RCON_MAX_BACKOFF_MINUTES=30              # Maximum backoff time
RCON_DORMANT_RETRY_MINUTES=60            # Dormant server retry interval

# Database Connection Pool Configuration
DB_MAX_CONNECTIONS=10                     # Maximum connections in pool
DB_MIN_CONNECTIONS=2                      # Minimum connections to maintain
DB_CONNECTION_TIMEOUT=30000               # Timeout for acquiring connection (ms)
DB_IDLE_TIMEOUT=300000                    # Maximum idle time (ms)
DB_HEALTH_CHECK_INTERVAL=60000            # Health check interval (ms)
DB_MAX_RETRIES=3                          # Maximum retries for operations

# Observability (opt-in). See docs/OBSERVABILITY.md.
# When true, the daemon binds METRICS_PORT and runs its 15s gauge interval.
METRICS_ENABLED=false
METRICS_PORT=9091
