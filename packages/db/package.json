{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf node_modules dist .turbo",
    "db:generate": "rm -rf generated/prisma && prisma generate --no-hints",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset && pnpm db:seed && pnpm db:seed:geo",
    "db:reset:dev": "pnpm db:reset && pnpm db:seed:dev",
    "db:seed": "tsx src/seed.ts",
    "db:seed:dev": "tsx src/seed-dev.ts",
    "db:seed:geo": "tsx src/scripts/seed-geoip.ts",
    "db:geo:update": "tsx src/scripts/seed-geoip.ts update",
    "db:run-sql": "tsx src/scripts/run-sql.ts",
    "db:test:prepare": "dotenv -e .env.test -- prisma db push",
    "db:test:reset": "dotenv -e .env.test -- prisma db push --force-reset",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "better-auth": "^1.6.11",
    "dbgate-query-splitter": "^4.12.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-prisma": "^4.14.3",
    "@pothos/plugin-relay": "^4.7.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/unzipper": "^0.10.11",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "glob": "^13.0.6",
    "prisma-generator-pothos-codegen": "^0.7.2",
    "ts-deepmerge": "^7.0.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  },
  "exports": {
    "./client": "./src/client.ts",
    "./seed": "./src/seed.ts",
    "./seed-dev": "./src/seed-dev.ts",
    "./graphql/types": "./generated/graphql/pothos-types.ts",
    "./graphql/inputs": "./generated/graphql/pothos-inputs.ts",
    "./graphql/crud": "./generated/graphql/pothos-inputs/autocrud.ts",
    "./generated/prisma/*": "./generated/prisma/*"
  }
}
