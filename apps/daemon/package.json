{
  "name": "daemon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx watch src/main.ts",
    "build": "tsc",
    "lint": "eslint . --ext .ts --max-warnings 0",
    "lint:fix": "eslint . --ext .ts --fix",
    "udp-dump": "tsx scripts/udp-dump.ts",
    "udp-debug": "tsx scripts/udp-debug.ts",
    "check-types": "tsc --noEmit",
    "test": "vitest run --silent",
    "test:coverage": "vitest run --coverage --silent",
    "test:integration": "vitest run --config vitest.integration.config.mjs",
    "test:e2e": "vitest run --config vitest.e2e.config.mjs",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "dependencies": {
    "@repo/observability": "workspace:*",
    "amqplib": "^0.10.9",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/crypto": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/amqplib": "^0.10.8",
    "@types/node": "^25.8.0",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6",
    "vitest-mock-extended": "^3.1.1"
  }
}
