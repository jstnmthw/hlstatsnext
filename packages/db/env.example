# Database Configuration
# Copy this file to .env and update with your actual database credentials
# Format: mysql://username:password@host:port/database_name
#
# Pool tuning (recommended for daemon production load):
#   ?connection_limit=N        — total Prisma pool size. Size to roughly
#                                EventConsumer.concurrency * avg_db_calls_per_event * 1.5.
#                                Default (Prisma): num_physical_cpus * 2 + 1.
#                                Under burst load + DB contention the default is easy
#                                to exhaust; 30–50 is typical for the daemon.
#   &pool_timeout=10           — seconds a query waits for a free connection
#                                before throwing. 10s is a sane upper bound.
#   &connect_timeout=10        — seconds to wait for initial TCP connect.
# Example: mysql://user:pass@host:3306/db?connection_limit=30&pool_timeout=10&connect_timeout=10
DATABASE_URL="mysql://hlstatsnext:changeme@localhost:3306/hlstatsnext"

# MaxMind credentials for GeoLite2 downloads (Basic Auth)
# See MaxMind docs: use Account ID + License Key
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=