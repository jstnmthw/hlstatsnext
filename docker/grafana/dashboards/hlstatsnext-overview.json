{
  "uid": "hlstatsnext-overview",
  "title": "HLStatsNext - Overview",
  "tags": ["hlstatsnext", "overview"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "panels": []
    },
    {
      "id": 2,
      "title": "Active Players",
      "description": "Live count of connected human players (open sessions, excludes bots).",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "blue", "value": null}]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": {"calc": "lastNotNull", "fields": "", "values": false}
      },
      "targets": [
        {"expr": "sum(active_players_count) or vector(0)", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "title": "Active Bots",
      "description": "Live count of connected bots. These still incur processing load when a server's IgnoreBots config is disabled.",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "purple", "value": null}]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": {"calc": "lastNotNull", "fields": "", "values": false}
      },
      "targets": [
        {"expr": "sum(active_bots_count) or vector(0)", "refId": "A"}
      ]
    },
    {
      "id": 4,
      "title": "Events / sec",
      "description": "Rate of events processed across all event types.",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": {"calc": "lastNotNull", "fields": "", "values": false}
      },
      "targets": [
        {"expr": "sum(rate(events_processed_total[1m])) or vector(0)", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "title": "Queue Depth",
      "description": "Messages waiting (ready) across all RabbitMQ consumer queues. 0 means the consumer is keeping up with the inbound rate.",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 200}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": {"calc": "lastNotNull", "fields": "", "values": false}
      },
      "targets": [
        {"expr": "sum(queue_depth) or vector(0)", "refId": "A"}
      ]
    },
    {
      "id": 6,
      "title": "Slow Queries",
      "description": "Rate of database queries taking longer than 1s.",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 5},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": {"calc": "lastNotNull", "fields": "", "values": false}
      },
      "targets": [
        {"expr": "(sum(rate(database_query_duration_seconds_count[5m])) - sum(rate(database_query_duration_seconds_bucket{le=\"1.0\"}[5m]))) or vector(0)", "refId": "A"}
      ]
    },
    {
      "id": 7,
      "title": "Failed Queries",
      "description": "Rate of database queries that returned an error.",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 5},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0.001}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": {"calc": "lastNotNull", "fields": "", "values": false}
      },
      "targets": [
        {"expr": "sum(rate(database_queries_total{success=\"false\"}[5m])) or vector(0)", "refId": "A"}
      ]
    },
    {
      "id": 8,
      "title": "CPU Usage",
      "description": "Daemon process CPU usage. 100% = one full core.",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 5},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.7},
              {"color": "red", "value": 0.9}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": {"calc": "lastNotNull", "fields": "", "values": false}
      },
      "targets": [
        {"expr": "sum(rate(process_cpu_seconds_total{job=\"hlstats-daemon\"}[5m])) or vector(0)", "refId": "A"}
      ]
    },
    {
      "id": 9,
      "title": "Memory (RSS)",
      "description": "Daemon process resident set size.",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 5},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": {"calc": "lastNotNull", "fields": "", "values": false}
      },
      "targets": [
        {"expr": "sum(process_resident_memory_bytes{job=\"hlstats-daemon\"})", "refId": "A"}
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Event Processing",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "panels": []
    },
    {
      "id": 11,
      "title": "Events Processed per Second",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "right", "showLegend": true, "calcs": []},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"expr": "sum by (event_type) (rate(events_processed_total[1m]))", "legendFormat": "{{event_type}}", "refId": "A"}
      ]
    },
    {
      "id": 12,
      "title": "Event Processing Duration (p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "right", "showLegend": true, "calcs": []},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (event_type, le) (rate(event_processing_duration_seconds_bucket[5m])))", "legendFormat": "{{event_type}}", "refId": "A"}
      ]
    },
    {
      "id": 13,
      "type": "row",
      "title": "Database",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "panels": []
    },
    {
      "id": 14,
      "title": "Query Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 19},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"expr": "sum by (operation, table) (rate(database_queries_total[1m]))", "legendFormat": "{{operation}} - {{table}}", "refId": "A"}
      ]
    },
    {
      "id": 15,
      "title": "Query Duration (p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 19},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (operation, table, le) (rate(database_query_duration_seconds_bucket[5m])))", "legendFormat": "{{operation}} - {{table}}", "refId": "A"}
      ]
    },
    {
      "id": 16,
      "title": "Query Duration (p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 19},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"expr": "histogram_quantile(0.99, sum by (operation, table, le) (rate(database_query_duration_seconds_bucket[5m])))", "legendFormat": "{{operation}} - {{table}}", "refId": "A"}
      ]
    },
    {
      "id": 17,
      "title": "Queries by Table",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 27},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "palette-classic"},
          "custom": {"hideFrom": {"tooltip": false, "viz": false, "legend": false}}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"]},
        "pieType": "donut",
        "tooltip": {"mode": "single", "sort": "desc"},
        "reduceOptions": {"calc": "lastNotNull", "fields": "", "values": false}
      },
      "targets": [
        {"expr": "sum by (table) (rate(database_queries_total[5m]))", "legendFormat": "{{table}}", "refId": "A"}
      ]
    },
    {
      "id": 18,
      "title": "Queries by Operation",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 27},
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "palette-classic"},
          "custom": {"hideFrom": {"tooltip": false, "viz": false, "legend": false}}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"]},
        "pieType": "donut",
        "tooltip": {"mode": "single", "sort": "desc"},
        "reduceOptions": {"calc": "lastNotNull", "fields": "", "values": false}
      },
      "targets": [
        {"expr": "sum by (operation) (rate(database_queries_total[5m]))", "legendFormat": "{{operation}}", "refId": "A"}
      ]
    },
    {
      "id": 19,
      "type": "row",
      "title": "System Resources",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 35},
      "panels": []
    },
    {
      "id": 20,
      "title": "CPU Usage",
      "description": "Daemon process CPU usage derived from process_cpu_seconds_total. 100% = one full core.",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "single", "sort": "desc"}
      },
      "targets": [
        {"expr": "sum(rate(process_cpu_seconds_total{job=\"hlstats-daemon\"}[5m]))", "legendFormat": "CPU", "refId": "A"}
      ]
    },
    {
      "id": 21,
      "title": "Memory Usage",
      "description": "Daemon process memory. RSS is total resident memory; heap used/total are the V8 JS heap; external covers Buffers and C++ objects.",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "opacity",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {"expr": "sum(process_resident_memory_bytes{job=\"hlstats-daemon\"})", "legendFormat": "RSS (resident)", "refId": "A"},
        {"expr": "sum(process_heap_bytes{job=\"hlstats-daemon\"})", "legendFormat": "Heap used", "refId": "B"},
        {"expr": "sum(process_heap_total_bytes{job=\"hlstats-daemon\"})", "legendFormat": "Heap total", "refId": "C"},
        {"expr": "sum(process_external_memory_bytes{job=\"hlstats-daemon\"})", "legendFormat": "External (buffers)", "refId": "D"}
      ]
    }
  ]
}
